# Plantilla de variables de entorno. Copiar a .env.local y ajustar.
#   cp .env.example .env.local
#
# En producción, reemplazar cada valor por la URL real del microservicio desplegado,
# por ejemplo: NEXT_PUBLIC_API_AUTH=https://auth.emplea-humboldt.com
#
# Nota: estas variables se "hornean" en el build de Next.js, así que al cambiarlas
# hay que volver a construir el frontend (npm run build) para que tomen efecto.
NEXT_PUBLIC_API_AUTH=http://localhost:8000
NEXT_PUBLIC_API_EMPLEOS=http://localhost:8001
NEXT_PUBLIC_API_POSTULACIONES=http://localhost:8002
NEXT_PUBLIC_API_SEGUIMIENTO=http://localhost:8003
NEXT_PUBLIC_API_NOTIFICACIONES=http://localhost:8004
