# Plantilla de variables de entorno. Copiar a .env.local y ajustar.
#   cp .env.example .env.local
#
# En desarrollo local (docker-compose): usar http://localhost:3000 (con proxy en Next.js)
# En producción: Amplify inyecta automáticamente la URL del API Gateway desplegado
#
# Nota: estas variables se "hornean" en el build de Next.js, así que al cambiarlas
# hay que volver a construir el frontend (npm run build) para que tomen efecto.
#
# El API Gateway enruta automáticamente:
#   /autenticacion/* → Microservicio de Autenticación (puerto 8000)
#   /empleos/* → Microservicio de Empleos (puerto 8001)
#   /postulaciones/* → Microservicio de Postulaciones (puerto 8002)
#   /seguimiento/* → Microservicio de Seguimiento (puerto 8003)
#   /notificaciones/* → Microservicio de Notificaciones (puerto 8004)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
